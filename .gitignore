# ── Python cache & bytecode ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Package / distribution ─────────────────────────────────────────────────
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Environment variables & secrets ───────────────────────────────────────
.env
.env.local
.env.*.local
*.secret
.streamlit/secrets.toml

# ── Temp / editor files ────────────────────────────────────────────────────
*.bak
*.tmp
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Generated outputs ──────────────────────────────────────────────────────
*.pdf
reports/

# ── Data files (keep examples, ignore user data) ──────────────────────────
*.csv
!examples/*.csv

# ── ML model cache & artefacts ────────────────────────────────────────────
*.pkl
*.joblib
*.h5
models/
.model_cache/

# ── App database ──────────────────────────────────────────────────────────
risk_history.db

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── Test coverage ─────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
